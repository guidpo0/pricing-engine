# Application environment
APP_ENV=development
LOG_LEVEL=INFO

# Scheduled job hours (24h format, UTC)
CURVE_UPDATE_HOUR=8
IPCA_UPDATE_HOUR=9

# BCB SGS API base URL
BCB_SGS_BASE_URL=https://api.bcb.gov.br/dados/serie/bcdata.sgs

# HTTP client timeout (seconds)
HTTP_TIMEOUT=30

# BRAPI config
BRAPI_BASE_URL=https://brapi.dev/api
BRAPI_TOKEN=your_token_here

# TwelveData config
TWELVE_DATA_BASE_URL=https://api.twelvedata.com
TWELVE_DATA_API_TOKEN=your_twelve_data_token_here

# CoinMarketCap config
COIN_MARKET_BASE_URL=https://pro-api.coinmarketcap.com
COIN_MARKET_API_TOKEN=your_coin_market_cap_token_here

# AwesomeAPI config
AWESOME_API_BASE_URL=https://economia.awesomeapi.com.br
